# swapclaw — environment configuration
# See AGENTS.md for full documentation.

# Required: command to spawn the ACP agent process
SWAPCLAW_AGENT_COMMAND=claude

# Optional: space-separated arguments for the agent command
# SWAPCLAW_AGENT_ARGS=--model opus

# Optional: directory for session data and database (default: ~/.swapclaw)
# SWAPCLAW_DATA_DIR=~/.swapclaw

# Optional: Docker image for sandbox containers (default: alpine:latest)
# SWAPCLAW_CONTAINER_IMAGE=alpine:latest

# Optional: maximum prompt execution time in ms (default: 300000)
# SWAPCLAW_CONTAINER_TIMEOUT=300000

# Optional: container idle timeout before teardown in ms (default: 60000)
# SWAPCLAW_IDLE_TIMEOUT=60000

# Optional: maximum concurrent sessions (default: 3)
# SWAPCLAW_MAX_CONCURRENT=3

# Optional: timezone for session formatting (default: system timezone)
# SWAPCLAW_TIMEZONE=America/New_York
