{
	"name": "swapclaw",
	"version": "0.1.1",
	"description": "Container-isolated agent runtime over the Agent Client Protocol (ACP)",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"swapclaw": "dist/index.js"
	},
	"files": ["dist", "templates"],
	"scripts": {
		"build": "tsc",
		"start": "bun run src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"keywords": ["acp", "agent", "container", "sandbox", "runtime", "docker"],
	"author": "arielarevalo",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/arielarevalo/swapclaw.git"
	},
	"homepage": "https://arielarevalo.github.io/swapclaw/",
	"bugs": {
		"url": "https://github.com/arielarevalo/swapclaw/issues"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.17.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.3.11",
		"@types/node": "^22.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"license": "MIT"
}
